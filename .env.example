# ──────────────────────────────────────────────────────────────
#  AutoGarant — environment variables example
#  Copy this file to `.env` and fill in the real values.
#  cp .env.example .env
# ──────────────────────────────────────────────────────────────

# --- Telegram ---
# Token from @BotFather
BOT_TOKEN=123456789:AAExampleBotTokenReplaceMe

# Comma-separated list of admin Telegram user IDs (optional)
ADMIN_IDS=

# --- PostgreSQL ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=autogarant
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=autogarant

# --- Redis (FSM / cache storage) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# --- App ---
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
