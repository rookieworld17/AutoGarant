# AutoGarant — copy to .env and fill in real values:  cp .env.example .env

# --- Telegram ---
# Token from @BotFather
BOT_TOKEN=123456789:AAExampleBotTokenReplaceMe
# Comma-separated admin Telegram user IDs (optional)
ADMIN_IDS=

# --- PostgreSQL ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=autogarant
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=autogarant

# --- Redis (FSM / cache) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# --- Wallet ---
# Deposit commission, percent.
DEPOSIT_COMMISSION_PERCENT=2
# Withdrawal commission, percent (held from the payout).
WITHDRAW_COMMISSION_PERCENT=0
# Telegram id that receives commissions via CryptoBot; empty → first ADMIN_IDS.
COMMISSION_TG_ID=

# --- Crypto Pay (CryptoBot) ---
CRYPTO_PAY_TOKEN=
CRYPTO_PAY_TESTNET=true

# --- App ---
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
